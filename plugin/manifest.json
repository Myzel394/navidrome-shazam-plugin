{
  "name": "Shazam Plugin",
  "author": "Myzel394",
  "version": "0.1.0",
  "description": "Scrape lyrics from Shazam",
  "permissions": {
    "http": {
      "reason": "Scrape lyrics from Shazam",
      "requiredHosts": [
        "www.shazam.com",
        "cdn.shazam.com"
      ]
    }
  },
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "shazam_search_country": {
          "type": "string",
          "default": "US",
          "description": "The country code to use when searching for lyrics on Shazam; You should set this to the country you are in for best results."
        }
      }
    }
  }
}
